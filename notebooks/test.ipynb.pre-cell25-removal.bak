   "cell_type": "code",
   "source": "# === PARITY BASELINE CAPTURE — Phase 1 step 3 (single run, option a) ===\n# Run once. Reads from the live kernel state.\n# Writes to notes/notes_code/parity_baseline/.\n\nimport shutil\nfrom pathlib import Path\nimport numpy as np\nimport pandas as pd\nimport joblib\nfrom sklearn.metrics import roc_curve, precision_recall_curve, average_precision_score\nfrom sklearn.calibration import calibration_curve as _cal_curve\n\n# --- Destination root ---\nWORKSPACE_ROOT = Path(DATA_DIR).resolve().parent.parent  # code/data -> code -> workspace\nBASELINE_ROOT  = WORKSPACE_ROOT / \"notes\" / \"notes_code\" / \"parity_baseline\"\n\nCSV_DIR     = BASELINE_ROOT / \"csv\"\nPARQUET_DIR = BASELINE_ROOT / \"parquet\"\nMODELS_DIR  = BASELINE_ROOT / \"models\"\nARRAYS_DIR  = BASELINE_ROOT / \"arrays\"\n\nfor d in (CSV_DIR, PARQUET_DIR, MODELS_DIR, ARRAYS_DIR):\n    d.mkdir(parents=True, exist_ok=True)\n\nprint(f\"Baseline root: {BASELINE_ROOT}\")\nprint()\n\n# --- Items 1-3: copy the three CSVs cell 24 wrote ---\nprocessed = Path(DATA_DIR) / \"processed\"\nfor name in (\"model_df_clean.csv\", \"feature_importance.csv\", \"model_summary.csv\"):\n    src = processed / name\n    dst = CSV_DIR / name\n    shutil.copy2(src, dst)\n    print(f\"  csv/         {name}  ({src.stat().st_size} bytes)\")\n\n# --- Items 4-7: copy the four parquet feature caches ---\ncache = processed / \"cache\"\nfor name in (\"road_features.parquet\", \"rail_features.parquet\",\n             \"fence_features.parquet\", \"speedlimit_features.parquet\"):\n    src = cache / name\n    dst = PARQUET_DIR / name\n    shutil.copy2(src, dst)\n    print(f\"  parquet/     {name}  ({src.stat().st_size} bytes)\")\n\n# --- Items 8-9: joblib dumps ---\njoblib.dump(rf_final,      MODELS_DIR / \"rf_final.joblib\")\njoblib.dump(rf_calibrated, MODELS_DIR / \"rf_calibrated.joblib\")\nprint(f\"  models/      rf_final.joblib\")\nprint(f\"  models/      rf_calibrated.joblib\")\n\n# --- Item 10: behaviour signatures ---\nX_all = model_df_clean[FEATURES]\nnp.save(ARRAYS_DIR / \"rf_final_predictions.npy\",\n        rf_final.predict_proba(X_all)[:, 1])\nnp.save(ARRAYS_DIR / \"rf_calibrated_predictions.npy\",\n        rf_calibrated.predict_proba(X_all)[:, 1])\nprint(f\"  arrays/      rf_final_predictions.npy\")\nprint(f\"  arrays/      rf_calibrated_predictions.npy\")\n\n# --- Item 11: per-fold metrics dataframe ---\nresults_df.to_csv(ARRAYS_DIR / \"results_df.csv\",\n                  index=False, lineterminator=\"\\n\")\nprint(f\"  arrays/      results_df.csv  ({len(results_df)} rows)\")\n\n# --- Items 12-13: OOF arrays ---\nnp.save(ARRAYS_DIR / \"oof_probs.npy\",  np.asarray(oof_probs))\nnp.save(ARRAYS_DIR / \"oof_labels.npy\", np.asarray(oof_labels))\nprint(f\"  arrays/      oof_probs.npy   ({len(oof_probs)} elements)\")\nprint(f\"  arrays/      oof_labels.npy  ({len(oof_labels)} elements)\")\n\n# --- Item 14: mean per-feature importance ---\nmean_importance.to_csv(ARRAYS_DIR / \"mean_importance.csv\",\n                       header=[\"importance\"], lineterminator=\"\\n\")\nprint(f\"  arrays/      mean_importance.csv  ({len(mean_importance)} features)\")\n\n# --- Item 15: calibration curve ---\n_prob_true, _prob_pred = _cal_curve(oof_labels, oof_probs, n_bins=10)\npd.DataFrame({\"prob_pred\": _prob_pred, \"prob_true\": _prob_true}).to_csv(\n    ARRAYS_DIR / \"calibration_curve.csv\",\n    index=False, lineterminator=\"\\n\",\n)\nprint(f\"  arrays/      calibration_curve.csv  ({len(_prob_pred)} bins)\")\n\n# --- Item 16: ROC curve WITH thresholds ---\n_fpr, _tpr, _roc_th = roc_curve(oof_labels, oof_probs)\npd.DataFrame({\"fpr\": _fpr, \"tpr\": _tpr, \"thresholds\": _roc_th}).to_csv(\n    ARRAYS_DIR / \"roc_curve.csv\",\n    index=False, lineterminator=\"\\n\",\n)\nprint(f\"  arrays/      roc_curve.csv  ({len(_fpr)} points)\")\n\n# --- Item 17: PR curve WITH thresholds + AP scalar ---\n_prec, _rec, _pr_th = precision_recall_curve(oof_labels, oof_probs)\n_pr_th_padded = np.concatenate([_pr_th, [np.nan]])\npd.DataFrame({\"precision\": _prec, \"recall\": _rec, \"thresholds\": _pr_th_padded}).to_csv(\n    ARRAYS_DIR / \"pr_curve.csv\",\n    index=False, lineterminator=\"\\n\",\n)\n_ap = average_precision_score(oof_labels, oof_probs)\n(ARRAYS_DIR / \"pr_average_precision.txt\").write_text(f\"{_ap:.18g}\\n\")\nprint(f\"  arrays/      pr_curve.csv  ({len(_prec)} points)\")\nprint(f\"  arrays/      pr_average_precision.txt  (AP = {_ap:.6f})\")\n\n# --- Item 18: spatial risk-map per-cell aggregation ---\n_cell_risk = (\n    model_df_clean.assign(\n        risk_prob=rf_final.predict_proba(model_df_clean[FEATURES])[:, 1]\n    )\n    .groupby(\"cell_id\")[\"risk_prob\"]\n    .mean()\n    .reset_index()\n)\n_cell_risk.to_csv(ARRAYS_DIR / \"cell_risk.csv\",\n                  index=False, lineterminator=\"\\n\")\nprint(f\"  arrays/      cell_risk.csv  ({len(_cell_risk)} cells)\")\n\n# --- Item 19: feature-importance-by-group sums ---\n_groups = {\n    \"roads\":   [\"road_density\", \"nearest_road_distance_m\"],\n    \"fences\":  [\"fence_density\", \"fence_near_10km\"],\n    \"weather\": [\"temp_mean\", \"temp_min\", \"temp_max\", \"precip_total\"],\n    \"species\": [\"roe_deer_lag1\", \"moose_lag1\", \"wild_boar_lag1\", \"fallow_deer_lag1\"],\n    \"light\":   [\"night_lag1\", \"day_lag1\", \"dawn_lag1\", \"dusk_lag1\"],\n    \"hunting\": [\"moose_hunting_frac\", \"wild_boar_hunting_frac\",\n                \"roe_deer_hunting_frac\", \"fallow_deer_hunting_frac\"],\n    \"rutting\": [\"moose_rut_frac\", \"roe_deer_rut_frac\",\n                \"wild_boar_rut_frac\", \"fallow_deer_rut_frac\"],\n    \"speed\":   [\"speedlimit_mean_weighted\", \"speedlimit_90plus_share\"],\n    \"rail\":    [\"rail_density\", \"rail_near_10km\"],\n}\n_group_imp = pd.Series(\n    {k: float(mean_importance[v].sum()) for k, v in _groups.items()},\n    name=\"importance_sum\",\n).sort_index()\n_group_imp.to_csv(ARRAYS_DIR / \"group_importance.csv\",\n                  header=[\"importance_sum\"], index_label=\"group\",\n                  lineterminator=\"\\n\")\nprint(f\"  arrays/      group_importance.csv  ({len(_group_imp)} groups)\")\n\nprint()\nprint(\"=== run-1 capture complete ===\")\n\n# --- File-count sanity check ---\ncounts = {d.name: sum(1 for _ in d.iterdir()) for d in (CSV_DIR, PARQUET_DIR, MODELS_DIR, ARRAYS_DIR)}\nprint(f\"File counts: {counts}\")\nexpected = {\"csv\": 3, \"parquet\": 4, \"models\": 2, \"arrays\": 12}\nok = counts == expected\nprint(f\"Expected:    {expected}\")\nprint(f\"Match:       {ok}\")\n",
