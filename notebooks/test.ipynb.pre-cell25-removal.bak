   "cell_type": "code",
   "source": [
    "top_features = mean_importance.head(15)\n",
    "\n",
    "top_features.sort_values().plot(kind=\"barh\")\n",
    "plt.title(\"Top Feature Importances (Random Forest)\")\n",
    "plt.xlabel(\"Importance\")\n",
    "plt.show()"
   ],
